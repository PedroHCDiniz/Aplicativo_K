<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/unlock_title"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/unlock_instructions"
        android:textSize="16sp"
        android:layout_marginBottom="16dp" />

    <EditText
        android:id="@+id/editUnlockPassword"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/setup_password_hint"
        android:inputType="numberPassword"
        android:singleLine="true"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/buttonUnlock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/unlock_button" />

    <TextView
        android:id="@+id/textUnlockError"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/unlock_invalid_password"
        android:textColor="#D32F2F"
        android:textSize="14sp"
        android:layout_marginTop="16dp"
        android:visibility="gone" />

</LinearLayout>
