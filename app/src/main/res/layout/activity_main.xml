<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mainRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="28dp">

    <TextView
        android:id="@+id/textHomeTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="36dp"
        android:text="@string/app_name"
        android:textColor="#212121"
        android:textSize="26sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/textHomeDateLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/home_date_label"
        android:textColor="#757575"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/textHomeDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="22dp"
        android:textColor="#212121"
        android:textSize="30sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/textHomeTimeLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/home_time_label"
        android:textColor="#757575"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/textHomeTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="22dp"
        android:textColor="#212121"
        android:textSize="42sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/textHomeBatteryLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/home_battery_label"
        android:textColor="#757575"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/textHomeBattery"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#212121"
        android:textSize="34sp"
        android:textStyle="bold" />

</LinearLayout>
