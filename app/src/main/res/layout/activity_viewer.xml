<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/textRoleLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/viewer_role_label"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/textStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/status_offline"
        android:textSize="16sp"
        android:layout_marginBottom="16dp" />

    <!-- SurfaceViewRenderer: componente do WebRTC que desenha o video
         recebido do transmissor. Fica vazio/preto ate uma VideoTrack remota
         ser anexada a ele (ver ViewerActivity). -->
    <org.webrtc.SurfaceViewRenderer
        android:id="@+id/surfaceRemoteVideo"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/buttonWatchScreen"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_watch_screen"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/buttonRequestShare"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_request_share"
        android:enabled="false"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/buttonStopWatching"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_stop_watching"
        android:enabled="false"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/buttonResetConfig"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_reset_config" />

</LinearLayout>
